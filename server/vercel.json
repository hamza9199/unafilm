{
    "version": 2,
    "builds": [
      {
        "src": "server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "server.js"
      }
    ],
    "functions": {
      "api/*": {
        "includeFiles": ["node_modules/sqlite3/**/*"]
      }
    }
    
  }